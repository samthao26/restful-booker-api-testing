    {
      "name": "3_POST_CreateBooking",
      "item": []
    },
    {
      "name": "Create booking",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"status code is 200\", function(){",
              "    pm.response.to.have.status(200)",
              "});",
              "pm.test(\"Booking id is a number\", function(){",
              "    const json = pm.response.json();",
              "    pm.expect(json.bookingid).to.be.a(\"number\");",
              "});",
              "pm.test(\"Booking data match request\", function(){",
              "    const json = pm.response.json();",
              "    pm.expect(json.booking.firstname).to.eq(\"Jim\");",
              "    pm.expect(json.booking.lastname).to.eq(\"Brown\");",
              "    pm.expect(json.booking.totalprice).to.eq(111);",
              "    pm.expect(json.booking.depositpaid).to.eq(true);",
              "    pm.expect(json.booking.bookingdates.checkin).to.eq(\"2018-01-01\");",
              "    pm.expect(json.booking.bookingdates.checkout).to.eq(\"2019-01-01\");",
              "})",
              "const json = pm.response.json();",
              "pm.environment.set(\"bookingid\", json.bookingid)"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"firstname\" : \"Jim\", \n    \"lastname\" : \"Brown\", \n    \"totalprice\": 111, \n    \"depositpaid\": true, \n    \"bookingdates\": {\n        \"checkin\": \"2018-01-01\", \n        \"checkout\": \"2019-01-01\"\n    }, \n    \"additionalneeds\": \"Breakfast\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/booking",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "booking"
          ]
        }
      },
      "response": []
    }
